[
  {
    "name": "minimax-chat",
    "method": "POST",
    "url": "https://api.minimax.io/v1/chat/completions",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer ${MINIMAX_API_KEY}"
    },
    "body": {
      "model": "MiniMax-M2.7",
      "messages": [
        {"role": "user", "content": "Reply with OK"}
      ],
      "max_tokens": 4
    },
    "expect": {
      "allowed_statuses": [200, 400, 401, 403, 429],
      "forbid_body_substrings": ["<html", "cf-chl", "Enable JavaScript and cookies to continue"]
    }
  },
